# Copy to .env.local and edit.
# Vite only exposes vars prefixed with VITE_.

# Base URL of the Symfony + API Platform backend.
# Leave empty when running the mock (VITE_USE_MOCK_API=true).
VITE_API_URL=https://api.newhair.cz

# Toggle the mock data layer.
#   true  → services return in-memory seed data; no HTTP calls made
#   false → services call VITE_API_URL (real backend must be up)
VITE_USE_MOCK_API=true

# (optional) Mercure hub URL for realtime message / notification subscriptions.
VITE_MERCURE_URL=https://api.newhair.cz/.well-known/mercure
